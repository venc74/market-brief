<!DOCTYPE html>
<html lang="bg">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Бриф · {{ date_human }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Spectral:wght@600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0b1220;          /* дълбоко мастилено синьо — небе преди отваряне */
    --panel: #111a2e;
    --panel-2: #16203a;
    --line: #233252;
    --text: #d9e1f2;
    --muted: #8593b3;
    --green: #34d399;
    --yellow: #fbbf24;
    --red: #f87171;
    {% if regime == "Offensive" %}--regime: #34d399; --regime-dim: rgba(52,211,153,.12);
    {% elif regime == "Cash" %}--regime: #f87171; --regime-dim: rgba(248,113,113,.12);
    {% else %}--regime: #fbbf24; --regime-dim: rgba(251,191,36,.12);{% endif %}
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--ink); color: var(--text);
    font-family: "IBM Plex Sans", sans-serif; font-size: 15px; line-height: 1.55;
  }
  .mono { font-family: "IBM Plex Mono", monospace; }
  .wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px 60px; }

  /* ── Хедър: режимът Е дизайнът ── */
  header {
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, var(--regime-dim), transparent 70%);
    padding: 36px 0 28px;
  }
  .header-inner { max-width: 1080px; margin: 0 auto; padding: 0 20px;
    display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 16px; }
  .masthead h1 { font-family: "Spectral", serif; font-size: 26px; font-weight: 700; letter-spacing: .3px; }
  .masthead .date { color: var(--muted); font-size: 13px; margin-top: 4px; }
  .regime-badge {
    font-family: "IBM Plex Mono", monospace; font-size: 22px; font-weight: 600;
    color: var(--regime); border: 2px solid var(--regime); border-radius: 6px;
    padding: 10px 22px; letter-spacing: 2px; text-transform: uppercase;
    box-shadow: 0 0 28px var(--regime-dim);
  }
  .regime-reason { color: var(--muted); font-size: 13px; text-align: right; max-width: 360px; margin-top: 6px; }

  section { margin-top: 44px; }
  h2 {
    font-family: "IBM Plex Mono", monospace; font-size: 13px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 2.5px; color: var(--muted);
    border-bottom: 1px solid var(--line); padding-bottom: 10px; margin-bottom: 20px;
  }
  h2::before { content: "// "; color: var(--regime); }

  /* ── Термометър ── */
  .thermo { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; }
  .t-card {
    background: var(--panel); border: 1px solid var(--line); border-radius: 8px;
    padding: 14px 16px; border-top: 3px solid var(--line);
  }
  .t-card.green { border-top-color: var(--green); }
  .t-card.yellow { border-top-color: var(--yellow); }
  .t-card.red { border-top-color: var(--red); }
  .t-name { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); }
  .t-val { font-family: "IBM Plex Mono", monospace; font-size: 21px; font-weight: 600; margin-top: 6px; }
  .t-label { font-size: 12px; color: var(--muted); margin-top: 4px; }

  .prose { background: var(--panel); border: 1px solid var(--line); border-left: 3px solid var(--regime);
    border-radius: 8px; padding: 20px 24px; font-size: 15.5px; }

  /* ── Сектори ── */
  .sectors { display: grid; gap: 12px; }
  .sector-row { background: var(--panel); border: 1px solid var(--line); border-radius: 8px;
    padding: 16px 20px; display: grid; grid-template-columns: 150px 1fr; gap: 16px; align-items: start; }
  .sector-name { font-weight: 600; }
  .sector-etf { font-family: "IBM Plex Mono", monospace; font-size: 12px; color: var(--regime); }
  .sector-chain { font-size: 14px; color: var(--text); }
  .sector-meta { font-size: 12px; color: var(--muted); margin-top: 4px; }

  /* ── Action карти ── */
  .stock-card { background: var(--panel); border: 1px solid var(--line); border-radius: 10px;
    margin-bottom: 22px; overflow: hidden; }
  .stock-head { padding: 18px 24px; display: flex; justify-content: space-between;
    align-items: baseline; flex-wrap: wrap; gap: 8px;
    background: var(--panel-2); border-bottom: 1px solid var(--line); }
  .ticker { font-family: "IBM Plex Mono", monospace; font-size: 24px; font-weight: 600; color: var(--regime); }
  .company { color: var(--muted); font-size: 14px; margin-left: 10px; }
  .price-tag { font-family: "IBM Plex Mono", monospace; font-size: 18px; }
  .stock-body { padding: 20px 24px; display: grid; grid-template-columns: 1.4fr 1fr; gap: 24px; }
  @media (max-width: 760px) { .stock-body, .sector-row { grid-template-columns: 1fr; } }
  .block h3 { font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px;
    color: var(--muted); margin: 14px 0 6px; }
  .block h3:first-child { margin-top: 0; }
  .kv { display: grid; grid-template-columns: 1fr auto; gap: 2px 14px;
    font-size: 13.5px; padding: 3px 0; border-bottom: 1px dotted var(--line); }
  .kv b { font-family: "IBM Plex Mono", monospace; font-weight: 500; text-align: right; }
  .why { font-size: 14.5px; }
  ul.tight { padding-left: 18px; font-size: 13.5px; }
  ul.tight li { margin: 4px 0; }
  .plan { background: var(--regime-dim); border: 1px solid var(--regime);
    border-radius: 8px; padding: 14px 16px; margin-top: 12px; }
  .plan .kv { border-bottom-color: rgba(255,255,255,.08); }
  .warn { color: var(--yellow); font-size: 13px; }

  /* ── Watchlist ── */
  .watch-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 14px; }
  .watch-card { background: var(--panel); border: 1px solid var(--line); border-radius: 8px; padding: 16px 18px; }
  .watch-card .ticker { font-size: 17px; color: var(--yellow); }
  .watch-card p { font-size: 13px; margin-top: 8px; color: var(--text); }
  .watch-trigger { font-size: 12.5px; color: var(--muted); margin-top: 8px;
    border-top: 1px dotted var(--line); padding-top: 8px; }

  /* ── v2: convergence маркери ── */
  .markers { display: inline-flex; gap: 6px; flex-wrap: wrap; margin-left: 12px; vertical-align: middle; }
  .marker { font-family: "IBM Plex Mono", monospace; font-size: 11px; font-weight: 600;
    padding: 2px 8px; border-radius: 4px; background: var(--regime-dim);
    color: var(--regime); border: 1px solid var(--regime); cursor: help; }
  .watch-card .markers { margin-left: 8px; }
  .borrow { font-size: 13px; color: var(--text); margin-top: 6px;
    padding-top: 6px; border-top: 1px dotted var(--line); }
  .borrow b { color: var(--yellow); }

  /* ── v2: thesis monitor ── */
  .theses { display: grid; gap: 12px; }
  .thesis { background: var(--panel); border: 1px solid var(--line); border-radius: 8px;
    padding: 16px 20px; border-left: 3px solid var(--line); }
  .thesis.active { border-left-color: var(--green); }
  .thesis.structural { border-left-color: var(--regime); }
  .thesis.watch { border-left-color: var(--muted); }
  .thesis-head { display: flex; justify-content: space-between; align-items: baseline;
    flex-wrap: wrap; gap: 8px; }
  .thesis-name { font-weight: 600; font-size: 15px; }
  .thesis-status { font-family: "IBM Plex Mono", monospace; font-size: 11px;
    text-transform: uppercase; letter-spacing: 1px; padding: 2px 8px; border-radius: 4px; }
  .thesis-status.active { color: var(--green); background: rgba(52,211,153,.12); }
  .thesis-status.structural { color: var(--regime); background: var(--regime-dim); }
  .thesis-status.watch { color: var(--muted); background: rgba(133,147,179,.12); }
  .thesis-tickers { font-family: "IBM Plex Mono", monospace; font-size: 13px;
    color: var(--regime); margin-top: 6px; }
  .thesis-chain { font-size: 13.5px; color: var(--text); margin-top: 8px; }
  .thesis-trigger { font-size: 12.5px; color: var(--green); margin-top: 6px; }
  .cot-direction { font-family: "IBM Plex Mono", monospace; font-size: 11px;
    text-transform: uppercase; letter-spacing: 1px; padding: 2px 8px; border-radius: 4px; }
  .cot-direction.bullish { color: var(--green); background: rgba(52,211,153,.12); }
  .cot-direction.bearish { color: var(--red); background: rgba(248,113,113,.12); }
  .cot-percentile { font-family: "IBM Plex Mono", monospace; font-size: 11px; color: var(--muted); }
  .cot-sub { font-size: 13px; margin-top: 8px; padding-top: 8px; border-top: 1px dashed var(--line); }
  .cot-sub-label { font-size: 11px; text-transform: uppercase; letter-spacing: .5px;
    color: var(--muted); margin-bottom: 3px; }
  .cot-tickers { font-family: "IBM Plex Mono", monospace; color: var(--regime); }

  /* ── v2: signal таблици (unusual options / splits) ── */
  .signal-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 10px; }
  .signal-chip { background: var(--panel); border: 1px solid var(--line); border-radius: 8px;
    padding: 12px 14px; }
  .signal-chip .sym { font-family: "IBM Plex Mono", monospace; font-size: 16px; font-weight: 600; }
  .signal-chip.calls .sym { color: var(--green); }
  .signal-chip.puts .sym { color: var(--red); }
  .signal-chip .note { font-size: 12px; color: var(--muted); margin-top: 4px; }
  .signal-chip .in-screen { font-size: 10.5px; font-family: "IBM Plex Mono", monospace;
    color: var(--regime); margin-top: 4px; }
  .split-tag { font-family: "IBM Plex Mono", monospace; font-size: 10px; text-transform: uppercase;
    letter-spacing: .5px; padding: 1px 6px; border-radius: 4px; margin-left: 8px; vertical-align: middle; }
  .split-tag.fwd { color: var(--green); background: rgba(52,211,153,.12); }
  .split-tag.rev { color: var(--red); background: rgba(248,113,113,.12); }

  /* ── v2: Superinvestor Moves ── */
  .si-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
  .si-card { background: var(--panel); border: 1px solid var(--line); border-radius: 8px; padding: 14px 16px; }
  .si-card.in-screen { border-color: var(--regime); box-shadow: 0 0 0 1px var(--regime-dim); }
  .si-top { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; }
  .si-sym { font-family: "IBM Plex Mono", monospace; font-size: 17px; font-weight: 600; color: var(--text); }
  .si-val { font-family: "IBM Plex Mono", monospace; font-size: 14px; color: var(--green); }
  .si-action { font-family: "IBM Plex Mono", monospace; font-size: 10.5px; text-transform: uppercase;
    letter-spacing: 1px; padding: 1px 7px; border-radius: 4px; background: rgba(52,211,153,.12); color: var(--green); }
  .si-mgr { font-size: 12.5px; color: var(--muted); margin-top: 6px; }
  .si-flag { font-size: 10.5px; font-family: "IBM Plex Mono", monospace; color: var(--regime); margin-top: 6px; }

  /* ── news_aggregator: Значими новини ── */
  .news-list { display: grid; gap: 10px; }
  .news-item { display: flex; gap: 12px; align-items: flex-start;
    background: var(--panel); border: 1px solid var(--line); border-radius: 8px; padding: 12px 16px; }
  .news-dot { flex: 0 0 auto; width: 7px; height: 7px; border-radius: 50%; background: var(--regime); margin-top: 8px; }
  .news-head { font-weight: 600; font-size: 14px; color: var(--text); }
  .news-why { font-size: 13.5px; color: var(--muted); }

  /* ── Magic Formula Top 10 ── */
  .mf-table { width: 100%; border-collapse: collapse; }
  .mf-table th, .mf-table td { text-align: left; padding: 9px 12px; border-bottom: 1px solid var(--line); font-size: 13.5px; }
  .mf-table th { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); font-weight: 600; }
  .mf-table td.n, .mf-table th.n { text-align: right; font-family: "IBM Plex Mono", monospace; }
  .mf-table .sym { font-family: "IBM Plex Mono", monospace; font-weight: 600; }
  .mf-table tr.in-screen .sym { color: var(--green); }
  .mf-rank { display: inline-block; width: 22px; height: 22px; line-height: 22px; text-align: center;
    border-radius: 50%; background: var(--regime-dim); color: var(--regime);
    font-family: "IBM Plex Mono", monospace; font-size: 12px; }

  /* ── Track Record: Open Positions таблица ── */
  .pos-table { width: 100%; border-collapse: collapse; }
  .pos-table th, .pos-table td { text-align: left; padding: 9px 12px; border-bottom: 1px solid var(--line); font-size: 13.5px; }
  .pos-table th { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); font-weight: 600; }
  .pos-table td.n, .pos-table th.n { text-align: right; font-family: "IBM Plex Mono", monospace; }
  .pos-table .sym { font-family: "IBM Plex Mono", monospace; font-weight: 600; }
  .pos-row-up { background: rgba(52,211,153,.06); }
  .pos-row-up td.n.pct { color: var(--green); }
  .pos-row-down { background: rgba(248,113,113,.06); }
  .pos-row-down td.n.pct { color: var(--red); }

  /* ── iborrowdesk search box ── */
  .borrow-box { background: var(--panel); border: 1px solid var(--line); border-radius: 8px; padding: 16px 18px; }
  .borrow-search { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  .borrow-search input { background: var(--panel-2); color: var(--text); border: 1px solid var(--line);
    border-radius: 6px; padding: 9px 12px; font-family: "IBM Plex Mono", monospace; font-size: 14px;
    text-transform: uppercase; width: 140px; color-scheme: dark; }
  .borrow-search button { background: var(--regime); color: var(--ink); border: none; border-radius: 6px;
    padding: 9px 18px; font-weight: 600; font-size: 13px; cursor: pointer; font-family: "IBM Plex Sans", sans-serif; }
  .borrow-search button:hover { filter: brightness(1.08); }
  #borrow-result { margin-top: 14px; font-size: 14px; }
  #borrow-result .bd-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px; margin-top: 6px; }
  #borrow-result .bd-cell { background: var(--panel-2); border: 1px solid var(--line); border-radius: 6px; padding: 10px 12px; }
  #borrow-result .bd-cell .lbl { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; }
  #borrow-result .bd-cell .val { font-family: "IBM Plex Mono", monospace; font-size: 17px; margin-top: 3px; }
  #borrow-result .hot { color: var(--red); } #borrow-result .ok { color: var(--green); }
  #borrow-msg { font-size: 13px; color: var(--muted); margin-top: 10px; }

  /* ── v2: NAAIM 52-седмичен chart ── */
  .naaim-wrap { background: var(--panel); border: 1px solid var(--line); border-radius: 8px; padding: 18px 20px; }
  .naaim-legend { display: flex; gap: 18px; font-size: 12px; color: var(--muted); margin-top: 10px; flex-wrap: wrap; }
  .naaim-legend i { display: inline-block; width: 11px; height: 11px; border-radius: 2px; margin-right: 5px; vertical-align: middle; }

  /* ── v2: исторически календар ── */
  .calendar { display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    background: var(--panel); border: 1px solid var(--line); border-radius: 8px; padding: 14px 18px; }
  .calendar label { font-size: 13px; color: var(--muted); }
  .calendar input[type="date"] { background: var(--panel-2); color: var(--text);
    border: 1px solid var(--line); border-radius: 6px; padding: 8px 10px;
    font-family: "IBM Plex Mono", monospace; font-size: 14px; color-scheme: dark; }
  .calendar button { background: var(--regime); color: var(--ink); border: none;
    border-radius: 6px; padding: 9px 18px; font-weight: 600; font-size: 13px; cursor: pointer;
    font-family: "IBM Plex Sans", sans-serif; }
  .calendar button:hover { filter: brightness(1.08); }
  .calendar .hint { font-size: 12px; color: var(--muted); }
  #history-frame { width: 100%; border: 1px solid var(--line); border-radius: 8px;
    margin-top: 16px; height: 0; transition: height .2s; background: var(--ink); }
  #history-msg { font-size: 13px; color: var(--yellow); margin-top: 10px; }

  footer { margin-top: 60px; border-top: 1px solid var(--line); padding-top: 20px;
    font-size: 12px; color: var(--muted); }
  @media (prefers-reduced-motion: no-preference) {
    .regime-badge { animation: pulse 4s ease-in-out infinite; }
    @keyframes pulse { 50% { box-shadow: 0 0 44px var(--regime-dim); } }
  }
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="masthead">
      <h1>Персонален AI Инвестиционен Бриф</h1>
      <div class="date mono">{{ date_human }} · генериран {{ generated_at }} CET · 90 мин преди US pre-market</div>
    </div>
    <div>
      <div class="regime-badge">{{ regime }}</div>
      <div class="regime-reason">{{ regime_reason }}</div>
    </div>
  </div>
</header>

<div class="wrap">

<section>
  <h2>Пазарен термометър</h2>
  <div class="thermo">
    {% for ind in thermometer.indicators %}
    {% if not ind.get('hide') %}
    <div class="t-card {{ ind.status }}">
      <div class="t-name">{{ ind.name }}</div>
      <div class="t-val">{{ ind.value if ind.value is not none else "—" }}</div>
      <div class="t-label">{{ ind.label }}</div>
    </div>
    {% endif %}
    {% endfor %}
  </div>
</section>

{% if news %}
<section>
  <h2>Значими новини · последните 24ч</h2>
  <div class="news-list">
    {% for n in news %}
    <div class="news-item">
      <span class="news-dot"></span>
      <div><span class="news-head">{{ n.headline }}</span>
        {% if n.why %}<span class="news-why"> — {{ n.why }}</span>{% endif %}</div>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

<section>
  <h2>Макро бриф</h2>
  <div class="prose">{{ macro_brief }}
  {% if regime_comment %}<br><br><span style="color:var(--muted)">{{ regime_comment }}</span>{% endif %}
  </div>
</section>

<section>
  <h2>Секторна карта · следващите 2–6 седмици</h2>
  <div class="sectors">
    {% for s in sector_logic %}
    <div class="sector-row">
      <div>
        <div class="sector-name">{{ s.sector }}</div>
        <div class="sector-etf">{{ s.etf }}</div>
      </div>
      <div>
        <div class="sector-chain">{{ s.chain }}</div>
        <div class="sector-meta">Хоризонт: {{ s.horizon_weeks }} седмици</div>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

{% if theses %}
<section>
  <h2>Геополитически тези · мониторинг</h2>
  <div class="theses">
    {% for th in theses %}
    <div class="thesis {{ th.status }}">
      <div class="thesis-head">
        <span class="thesis-name">{{ th.name }}</span>
        <span class="thesis-status {{ th.status }}">{{ "активна" if th.status == "active" else "структурна" if th.status == "structural" else "наблюдава се" }}</span>
      </div>
      <div class="thesis-tickers">{{ th.tickers|join("  ·  ") }}</div>
      <div class="thesis-chain">{{ th.chain }}</div>
      {% if th.trigger_reason %}<div class="thesis-trigger">▲ Тригер активен: {{ th.trigger_reason }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

<section>
  <h2>Action · {{ action|length }} тикъра</h2>
  {% for st in action %}
  {% set p = st.plan %}
  <div class="stock-card">
    <div class="stock-head">
      <div><span class="ticker">{{ st.ticker }}</span><span class="company">{{ st.company }} · {{ st.sector }}</span>
        {% if st.markers %}<span class="markers">{% for m in st.markers %}<span class="marker" title="{{ m.title }}">{{ m.tag }}</span>{% endfor %}</span>{% endif %}
      </div>
      <div class="price-tag">${{ st.price }} <span style="color:var(--muted);font-size:13px">pivot ${{ st.pivot }} ({{ st.pct_from_pivot }}%)</span></div>
    </div>
    <div class="stock-body">
      <div class="block">
        <h3>Защо точно сега</h3>
        <div class="why">{{ st.ai.why_now }}</div>
        <h3>Бизнес</h3>
        <div class="why">{{ st.ai.business_bg }}</div>
        <h3>Катализатори · 4–8 седмици</h3>
        <ul class="tight">{% for c in st.ai.catalysts %}<li>{{ c }}</li>{% endfor %}</ul>
        <h3>Рискове</h3>
        <ul class="tight">{% for r in st.ai.risks %}<li>{{ r }}</li>{% endfor %}</ul>
        {% if st.ai.warning %}<p class="warn">⚠ {{ st.ai.warning }}</p>{% endif %}
        <h3>Short Interest</h3>
        <div class="why" style="font-size:13.5px">{{ st.short_view.interpretation }}</div>
        {% if st.short_view.borrow %}<div class="borrow"><b>Borrow:</b> {{ st.short_view.borrow }}</div>{% endif %}
        <h3>Опции</h3>
        <div class="kv"><span>IV / IVR</span><b>{{ st.options.iv or "—" }}% / {{ st.options.iv_rank or "—" }}{% if st.options.iv_rank_quality %} ({{ st.options.iv_rank_quality }}){% endif %}</b></div>
        <div class="kv"><span>P/C ratio</span><b>{{ st.options.put_call_ratio or "—" }}</b></div>
