<script>
// ── NAAIM 52-седмичен chart (vanilla SVG, без външни библиотеки) ──────────
(function () {
  var el = document.getElementById("naaim-data");
  var svg = document.getElementById("naaim-chart");
  if (!el || !svg) return;
  var data;
  try { data = JSON.parse(el.textContent); } catch (e) { return; }
  var pts = (data.points || []).filter(function (p) { return p.value != null; });
  if (pts.length < 2) return;

  var W = 1000, H = 240, padL = 34, padR = 10, padT = 10, padB = 22;
  var minV = 0, maxV = 100;
  var x = function (i) { return padL + (W - padL - padR) * i / (pts.length - 1); };
  var y = function (v) { return padT + (H - padT - padB) * (1 - (v - minV) / (maxV - minV)); };
  var css = getComputedStyle(document.documentElement);
  var regime = css.getPropertyValue("--regime").trim() || "#fbbf24";
  var line = css.getPropertyValue("--line").trim() || "#233252";
  var muted = css.getPropertyValue("--muted").trim() || "#8593b3";
  var NS = "http://www.w3.org/2000/svg";
  function add(tag, attrs) {
    var n = document.createElementNS(NS, tag);
    for (var k in attrs) n.setAttribute(k, attrs[k]);
    svg.appendChild(n); return n;
  }
  // зони <30 (buy) и >90 (caution)
  add("rect", { x: padL, y: y(30), width: W - padL - padR, height: y(0) - y(30), fill: "rgba(52,211,153,.16)" });
  add("rect", { x: padL, y: y(100), width: W - padL - padR, height: y(90) - y(100), fill: "rgba(248,113,113,.16)" });
  // мрежа + етикети 0/30/50/90/100
  [0, 30, 50, 90, 100].forEach(function (v) {
    add("line", { x1: padL, y1: y(v), x2: W - padR, y2: y(v), stroke: line, "stroke-width": 1 });
    var t = add("text", { x: 4, y: y(v) + 4, fill: muted, "font-size": 11, "font-family": "monospace" });
    t.textContent = v;
  });
  // линия
  var d = pts.map(function (p, i) { return (i ? "L" : "M") + x(i).toFixed(1) + " " + y(p.value).toFixed(1); }).join(" ");
  add("path", { d: d, fill: "none", stroke: regime, "stroke-width": 2 });
  // маркери за екстремни седмици
  pts.forEach(function (p, i) {
    if (p.value < 30 || p.value > 90) {
      add("circle", { cx: x(i), cy: y(p.value), r: 3, fill: p.value < 30 ? "#34d399" : "#f87171" });
    }
  });
})();

// ── Исторически календар: отваря docs/archive/<date>.html в iframe ────────
(function () {
  var input = document.getElementById("hist-date");
  var btn = document.getElementById("hist-open");
  var avail = document.getElementById("hist-avail");
  var frame = document.getElementById("history-frame");
  var msg = document.getElementById("history-msg");
  if (!input || !btn) return;

  var dates = [];
  fetch("data/index.json", { cache: "no-store" })
    .then(function (r) { return r.ok ? r.json() : []; })
    .then(function (list) {
      dates = Array.isArray(list) ? list.sort() : [];
      if (dates.length) {
        input.min = dates[0];
        input.max = dates[dates.length - 1];
        input.value = dates[dates.length - 1];
        avail.textContent = dates.length + " налични дни (" + dates[0] + " → " + dates[dates.length - 1] + ")";
      } else {
        avail.textContent = "няма архивирани брифове все още";
      }
    })
    .catch(function () { avail.textContent = "архивът е недостъпен"; });

  function open() {
    var d = input.value;
    msg.hidden = true; frame.hidden = true; frame.style.height = "0";
    if (!d) return;
    if (dates.length && dates.indexOf(d) === -1) {
      msg.hidden = false;
      msg.textContent = "Няма бриф за " + d + " (уикенд, празник или извън архива).";
      return;
    }
    frame.src = "archive/" + d + ".html";
    frame.hidden = false;
    frame.style.height = "1400px";
  }
  btn.addEventListener("click", open);
})();

// ── iborrowdesk borrow-rate търсене (директно от браузъра, без backend) ───
(function () {
  var input = document.getElementById("borrow-input");
  var btn = document.getElementById("borrow-btn");
  var out = document.getElementById("borrow-result");
  var msg = document.getElementById("borrow-msg");
  if (!input || !btn) return;

  function cell(lbl, val, klass) {
    return '<div class="bd-cell"><div class="lbl">' + lbl + '</div>' +
           '<div class="val ' + (klass || "") + '">' + val + '</div></div>';
  }

  function render(sym, data) {
    var series = data.daily || data.data || data.feed || (Array.isArray(data) ? data : []);
    if (!series.length) { msg.textContent = "Няма borrow данни за " + sym + "."; return; }
    function F(o){ return o.fee != null ? o.fee : (o.rate != null ? o.rate : null); }
    function A(o){ return o.available != null ? o.available : (o.quantity != null ? o.quantity : o.availableShares); }
    var latest = series[series.length - 1];
    var fee = F(latest), avail = A(latest);
    var fees = series.slice(-5).map(F).filter(function (x) { return x != null; });
    var trend = fees.length < 2 ? "—" :
      fees[fees.length - 1] > fees[0] ? "покачващ ▲" :
      fees[fees.length - 1] < fees[0] ? "падащ ▼" : "стабилен";
    var feeKlass = fee >= 20 ? "hot" : "ok";
    var hist = series.slice(-10).map(function (s) {
      var a = A(s); return (a != null ? Number(a).toLocaleString("de-DE") : "—"); }).join(" · ");

    out.innerHTML =
      '<div style="font-family:\'IBM Plex Mono\',monospace;font-size:18px;font-weight:600;margin-bottom:4px">' + sym + '</div>' +
      '<div class="bd-grid">' +
        cell("Borrow Rate", (fee != null ? fee.toFixed(2) + "%" : "—"), feeKlass) +
        cell("Налични акции", (avail != null ? Number(avail).toLocaleString("de-DE") : "—")) +
        cell("Тренд на fee", trend) +
      '</div>' +
      '<div class="small" style="color:var(--muted);margin-top:10px">Налично (последни записи): ' + hist + '</div>';
    msg.textContent = fee >= 20
      ? "Висок borrow rate — акцията е трудна/скъпа за шортиране, натиск върху шортистите."
      : "Нормален borrow rate — евтино за шортиране, без особен squeeze натиск.";
  }

  function lookup() {
    var sym = (input.value || "").trim().toUpperCase();
    out.innerHTML = ""; msg.textContent = "";
    if (!sym) return;
    msg.textContent = "Зареждам " + sym + "…";
    var api = "https://iborrowdesk.com/api/ticker/" + encodeURIComponent(sym);
    // директно; при CORS блокаж — fallback през публичен CORS reader (премахни ако не искаш трета страна)
    fetch(api)
      .then(function (r) { if (!r.ok) throw new Error("HTTP " + r.status); return r.json(); })
      .then(function (d) { render(sym, d); })
      .catch(function () {
        return fetch("https://api.allorigins.win/raw?url=" + encodeURIComponent(api))
          .then(function (r) { return r.json(); })
          .then(function (d) { render(sym, d); })
          .catch(function (e) { msg.textContent = "Неуспех за " + sym + " (възможен CORS блокаж или невалиден тикър)."; });
      });
  }
  btn.addEventListener("click", lookup);
  input.addEventListener("keydown", function (e) { if (e.key === "Enter") lookup(); });
})();
</script>
</body>
</html>
